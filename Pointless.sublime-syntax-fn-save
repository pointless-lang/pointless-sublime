%YAML 1.2
---

file_extensions:
  - ptls

scope: source.pointless

variables:
  ident: '[a-zA-Z][a-zA-Z0-9]*'

contexts:
  prototype:
    - include: comment

  comment:
    - match: '--.*'
      scope: comment.pointless

  main:
    - include: number
    - include: string
    - include: rawString
    - include: field
    - include: constant
    - include: function
    - include: keyword
    - include: pipe
    - include: operator
    - include: punctuation
    - include: definition
    - include: call
    - include: name

  string:
    - match: '"'
      scope: punctuation.definition.string.begin.pointless
      push:
        - meta_include_prototype: false
        - meta_scope: string.quoted.double.pointless

        - match: '"'
          scope: punctuation.definition.string.end.pointless
          pop: true

        - match: '\\["\\nrt]|\\u[\dA-Fa-f]{4}'
          scope: constant.character.escape.pointless

        - match: '\\.'
          scope: invalid.illegal.invalid-escape.pointless

  rawString:
    - match: '(r)((#*)")'
      captures:
        1: storage.type.string.pointless
        2: punctuation.definition.string.begin.pointless
      push:
        - meta_include_prototype: false
        - meta_scope: string.quoted.double.raw.pointless
        - match: '"\3'
          scope: punctuation.definition.string.end.pointless
          pop: true

  number:
    - match: '\b(\d+(\.\d+)?|\.\d+)([eE][+-]?\d+)?\b'
      scope: constant.numeric.pointless

  field:
    - match: '{{ident}}\s*(:)'
      captures:
        1: variable.name.pointless
        2: punctuation.separator.pointless

    - match: '(\.)({{ident}})\s*(?=\()'
      captures:
        1: punctuation.accessor
        2: variable.function.pointless

    - match: '(\.)({{ident}})'
      captures:
        1: punctuation.accessor
        2: variable.name.pointless

  constant:
    - match: '\b(true|false)\b'
      scope: constant.language.boolean.pointless

    - match: '\bnone\b'
      scope: constant.language.pointless

  function:
    - match: '(fn)(\()'
      captures:
        1: keyword.declaration.function.inline.pointless
        2: punctuation.section.parameters.begin.pointless
      push:
        - match: '{{ident}}|_\b'
          scope: variable.parameter.pointless

        - match: ','
          scope: punctuation.separator.pointless

        - match: '\)'
          scope: punctuation.section.parameters.end.pointless
          pop: true

        - match: '\S'
          scope: invalid.illegal.pointless

    - match: '(fn) ({{ident}})(?=\()'
      captures:
        1: keyword.declaration.function.inline.pointless
        2: entity.name.function.pointless
      push:
        - match: '{{ident}}|_\b'
          scope: variable.parameter.pointless

        - match: ','
          scope: punctuation.separator.pointless

        - match: '\('
          scope: punctuation.section.parameters.begin.pointless

        - match: '\)'
          scope: punctuation.section.parameters.end.pointless
          pop: true

        - match: '\S'
          scope: invalid.illegal.pointless

    - match: '{{ident}}(?=\s*=\s*fn)'
      scope: entity.name.function.pointless

  keyword:
    - match: '\b(and|not|or)\b'
      scope: keyword.operator.word.pointless

    - match: '\b(end|elif|else|fn|if|import|then|self)\b'
      scope: keyword.control.pointless

  pipe:
    - match: '\|=|\|'
      scope: keyword.operator.pointless
      push:
        - match: '{{ident}}(?=\.)'
          scope: variable.name.pointless

        - match: '(?!fn\b){{ident}}(?=[\s()?]|$)'
          scope: variable.function.pointless
          pop: true

        - match: '\.'
          scope: punctuation.accessor.pointless

        - match: '(?=\S)'
          pop: true

  operator:
    - match: '\||\?|\/|\+=|\+|\*\*=|\*\*|\*=|\*|>=|>|==|<=|<|\/=|-=|-|%=|%|!=|\$'
      scope: keyword.operator.pointless

  definition:
    - match: '=|\+=|-=|\*=|/=|\*\*=|%=(?!=)'
      scope: keyword.operator.assignment.pointless

  punctuation:
    - match: '\.'
      scope: punctuation.accessor

    - match: ','
      scope: punctuation.separator.pointless

    - match: '[\[\]{}()]'
      scope: punctuation.section.pointless

  call:
    - match: '(?!fn){{ident}}(?=\s*\()'
      scope: variable.function.pointless

  name:
    - match: '{{ident}}'
      scope: variable.name.pointless
